# ---------------------------------------------------------------------------
# Copy to `.env` and adjust.  `docker compose` reads this file automatically.
# ---------------------------------------------------------------------------

# --- Image -----------------------------------------------------------------
IMAGE=ghcr.io/zollo/logstash-azure-proxy
IMAGE_TAG=latest
LOGSTASH_VERSION=8.11.4

# --- Persistent queue ------------------------------------------------------
LS_QUEUE_PATH=/var/lib/logstash/queue
LS_QUEUE_MAX_BYTES=60gb

# --- Dead Letter Queue -----------------------------------------------------
# Un-processable events are written here (instead of dropped) and drained to
# the F5Telemetry_DLQ_CL table by the `dlq` pipeline.
LS_DLQ_PATH=/var/lib/logstash/dlq
LS_DLQ_MAX_BYTES=1gb

# --- HTTP input / API ports ------------------------------------------------
# HTTP_INPUT_PORT is intentionally NOT named HTTP_PORT: Logstash maps a
# HTTP_PORT env var onto its http.port setting, which conflicts with
# api.http.port (the Logstash monitoring API port, API_PORT below).
HTTP_INPUT_PORT=8080
API_PORT=9600

# --- JVM heap (majority of the container memory limit) ---------------------
# Override only if you need something other than 75% of the memory limit.
# LS_JAVA_OPTS=-XX:InitialRAMPercentage=75 -XX:MinRAMPercentage=75 -XX:MaxRAMPercentage=75

# --- Resource allocation ---------------------------------------------------
LS_CPU_LIMIT=2
LS_MEM_LIMIT=4g
LS_CPU_RESERVATION=1
LS_MEM_RESERVATION=2g

# --- Microsoft Sentinel output — Logs Ingestion API / DCR (REQUIRED) -------
# All five values are printed by the Terraform module in terraform/ once it has
# provisioned the DCE, DCR and the service principal:
#
#   terraform output -raw tenant_id
#   terraform output -raw client_id
#   terraform output -raw client_secret          # sensitive
#   terraform output -raw data_collection_endpoint_uri
#   terraform output -raw dcr_immutable_id
#
# Keep AZURE_CLIENT_SECRET out of source control; prefer the Logstash keystore
# or a container secret in production.
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_DCE_URI=
AZURE_DCR_IMMUTABLE_ID=

# Output tunables (plugin defaults).
AZURE_FLUSH_INTERVAL=5
AZURE_RETRANSMISSION_TIME=10
AZURE_COMPRESS_DATA=true

# --- F5 Telemetry Streaming -> per-category DCR streams --------------------
# Each F5 TS event category is routed to its own DCR stream, which the DCR maps
# to a `F5Telemetry_*_CL` custom table. Stream names use the Custom-<Table>_CL
# convention emitted by the Terraform module; override only if you renamed them.
AZURE_STREAM_LTM=Custom-F5Telemetry_LTM_CL
AZURE_STREAM_ASM=Custom-F5Telemetry_ASM_CL
AZURE_STREAM_SYSTEM=Custom-F5Telemetry_System_CL
AZURE_STREAM_AFM=Custom-F5Telemetry_AFM_CL
AZURE_STREAM_APM=Custom-F5Telemetry_APM_CL
AZURE_STREAM_AVR=Custom-F5Telemetry_AVR_CL
# Fallback stream for any event that cannot be classified as an F5 TS category.
AZURE_STREAM_EVENT=Custom-F5Telemetry_Event_CL
# Stream for un-processable events drained from the Dead Letter Queue.
AZURE_STREAM_DLQ=Custom-F5Telemetry_DLQ_CL

# --- Debugging -------------------------------------------------------------
# Set to true to also echo every processed event to the container logs.
DEBUG_STDOUT=false
