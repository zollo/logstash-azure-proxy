# ---------------------------------------------------------------------------
# Copy to `.env` and adjust.  `docker compose` reads this file automatically.
# ---------------------------------------------------------------------------

# --- Image -----------------------------------------------------------------
IMAGE=ghcr.io/zollo/logstash-azure-proxy
IMAGE_TAG=latest
LOGSTASH_VERSION=8.11.4

# --- Persistent queue ------------------------------------------------------
LS_QUEUE_PATH=/var/lib/logstash/queue
LS_QUEUE_MAX_BYTES=60gb

# --- HTTP input / API ports ------------------------------------------------
HTTP_PORT=8080
API_PORT=9600

# --- JVM heap (majority of the container memory limit) ---------------------
# Override only if you need something other than 75% of the memory limit.
# LS_JAVA_OPTS=-XX:InitialRAMPercentage=75 -XX:MinRAMPercentage=75 -XX:MaxRAMPercentage=75

# --- Resource allocation ---------------------------------------------------
LS_CPU_LIMIT=2
LS_MEM_LIMIT=4g
LS_CPU_RESERVATION=1
LS_MEM_RESERVATION=2g

# --- Azure Log Analytics (REQUIRED) ---------------------------------------
AZURE_WORKSPACE_ID=
AZURE_WORKSPACE_KEY=
AZURE_LOG_TABLE=logstash
AZURE_FLUSH_INTERVAL=5
AZURE_MAX_ITEMS=2000
