{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "description": "SRE-focused Azure Monitor log alerts (scheduled query rules) for F5 telemetry shipped by logstash-azure-proxy into Azure Log Analytics. Covers low-ingestion / no-data, ingestion latency, LTM error-rate and latency, ASM critical-attack spikes, and BIG-IP device health."
  },
  "parameters": {
    "workspaceResourceId": {
      "type": "string",
      "metadata": { "description": "Resource ID of the Log Analytics workspace receiving F5 telemetry (e.g. /subscriptions/<sub>/resourceGroups/<rg>/providers/Microsoft.OperationalInsights/workspaces/<ws>)." }
    },
    "location": {
      "type": "string",
      "defaultValue": "[resourceGroup().location]",
      "metadata": { "description": "Azure region for the alert rule resources. Should match the workspace region." }
    },
    "actionGroupResourceId": {
      "type": "string",
      "defaultValue": "",
      "metadata": { "description": "Optional resource ID of an Action Group to notify (PagerDuty / email / webhook / Teams). Leave blank to create the rules without notifications and wire them up later." }
    },
    "namePrefix": {
      "type": "string",
      "defaultValue": "F5",
      "metadata": { "description": "Prefix applied to every alert rule display name." }
    },
    "systemMinEvents": {
      "type": "int",
      "defaultValue": 1,
      "metadata": { "description": "Minimum System Poller (heartbeat) events expected in a 10-minute window. Default polling interval is 60s, so a single device should produce ~10." }
    },
    "ltmMinEvents": {
      "type": "int",
      "defaultValue": 1,
      "metadata": { "description": "Minimum LTM request-log events expected in a 15-minute window before low-ingestion fires. Tune to your floor of normal traffic." }
    },
    "asmMinEvents": {
      "type": "int",
      "defaultValue": 1,
      "metadata": { "description": "Minimum ASM events expected in a 60-minute window. ASM is event-driven and may be naturally sparse; raise the window or disable this rule in low-WAF-traffic environments." }
    },
    "ingestionLagP95Seconds": {
      "type": "int",
      "defaultValue": 300,
      "metadata": { "description": "p95 ingestion lag (seconds, event time vs. Azure index time) that indicates the proxy persistent queue is backing up or Azure is throttling." }
    },
    "ltm5xxThresholdPct": {
      "type": "int",
      "defaultValue": 5,
      "metadata": { "description": "LTM 5xx server-error rate (percent, over a 15-minute window) that triggers an alert. A minimum-volume guard is built into the query." }
    },
    "ltmLatencyP95Ms": {
      "type": "int",
      "defaultValue": 1000,
      "metadata": { "description": "LTM p95 response time (ms, over a 15-minute window) that indicates latency degradation." }
    },
    "asmCriticalThreshold": {
      "type": "int",
      "defaultValue": 25,
      "metadata": { "description": "Number of blocked, Critical-severity ASM events (per WAF policy, over a 5-minute window) that indicates an attack spike." }
    },
    "deviceCpuThresholdPct": {
      "type": "int",
      "defaultValue": 85,
      "metadata": { "description": "BIG-IP system CPU utilization (percent, latest System Poller snapshot per device) above which the device-saturation alert fires." }
    },
    "deviceMemThresholdPct": {
      "type": "int",
      "defaultValue": 90,
      "metadata": { "description": "BIG-IP system memory utilization (percent, latest System Poller snapshot per device) above which the device-saturation alert fires." }
    }
  },
  "variables": {
    "actionGroups": "[if(empty(parameters('actionGroupResourceId')), createArray(), createArray(parameters('actionGroupResourceId')))]"
  },
  "resources": [
    {
      "type": "Microsoft.Insights/scheduledQueryRules",
      "apiVersion": "2021-08-01",
      "name": "[concat(parameters('namePrefix'), '-System-Heartbeat-Lost')]",
      "location": "[parameters('location')]",
      "kind": "LogAlert",
      "properties": {
        "displayName": "[concat(parameters('namePrefix'), ' | System Poller heartbeat lost (no data)')]",
        "description": "No (or too few) F5 System Poller snapshots reached Log Analytics in the last 10 minutes. The System Poller is periodic (~60s), so this is the most reliable signal that the proxy is down, the container lost Azure connectivity, or the BIG-IP stopped polling. Primary no-data alarm.",
        "severity": 1,
        "enabled": true,
        "evaluationFrequency": "PT5M",
        "windowSize": "PT10M",
        "scopes": [ "[parameters('workspaceResourceId')]" ],
        "criteria": {
          "allOf": [
            {
              "query": "union isfuzzy=true (F5Telemetry_System_CL)\n| summarize Count = count()",
              "timeAggregation": "Total",
              "metricMeasureColumn": "Count",
              "operator": "LessThan",
              "threshold": "[parameters('systemMinEvents')]",
              "failingPeriods": { "numberOfEvaluationPeriods": 1, "minFailingPeriodsToAlert": 1 }
            }
          ]
        },
        "autoMitigate": true,
        "skipQueryValidation": true,
        "actions": { "actionGroups": "[variables('actionGroups')]" }
      }
    },
    {
      "type": "Microsoft.Insights/scheduledQueryRules",
      "apiVersion": "2021-08-01",
      "name": "[concat(parameters('namePrefix'), '-Ingestion-Stopped')]",
      "location": "[parameters('location')]",
      "kind": "LogAlert",
      "properties": {
        "displayName": "[concat(parameters('namePrefix'), ' | All F5 ingestion stopped (full outage)')]",
        "description": "No events of ANY F5 category (LTM/ASM/System/AFM/APM/AVR/fallback) reached Log Analytics in the last 15 minutes. Indicates a total data-path outage: proxy down, network path to Azure broken, or workspace credentials invalid.",
        "severity": 0,
        "enabled": true,
        "evaluationFrequency": "PT5M",
        "windowSize": "PT15M",
        "scopes": [ "[parameters('workspaceResourceId')]" ],
        "criteria": {
          "allOf": [
            {
              "query": "union isfuzzy=true\n  (F5Telemetry_LTM_CL),\n  (F5Telemetry_ASM_CL),\n  (F5Telemetry_System_CL),\n  (F5Telemetry_AFM_CL),\n  (F5Telemetry_APM_CL),\n  (F5Telemetry_AVR_CL),\n  (F5Telemetry_Event_CL)\n| summarize Count = count()",
              "timeAggregation": "Total",
              "metricMeasureColumn": "Count",
              "operator": "LessThan",
              "threshold": 1,
              "failingPeriods": { "numberOfEvaluationPeriods": 1, "minFailingPeriodsToAlert": 1 }
            }
          ]
        },
        "autoMitigate": true,
        "skipQueryValidation": true,
        "actions": { "actionGroups": "[variables('actionGroups')]" }
      }
    },
    {
      "type": "Microsoft.Insights/scheduledQueryRules",
      "apiVersion": "2021-08-01",
      "name": "[concat(parameters('namePrefix'), '-LTM-Low-Ingestion')]",
      "location": "[parameters('location')]",
      "kind": "LogAlert",
      "properties": {
        "displayName": "[concat(parameters('namePrefix'), ' | LTM low ingestion')]",
        "description": "LTM request-log volume in Log Analytics dropped below the expected floor over the last 15 minutes. Indicates the BIG-IP request-logging profile stopped streaming, or the proxy is dropping LTM traffic, while other categories may still be flowing.",
        "severity": 2,
        "enabled": true,
        "evaluationFrequency": "PT5M",
        "windowSize": "PT15M",
        "scopes": [ "[parameters('workspaceResourceId')]" ],
        "criteria": {
          "allOf": [
            {
              "query": "union isfuzzy=true (F5Telemetry_LTM_CL)\n| summarize Count = count()",
              "timeAggregation": "Total",
              "metricMeasureColumn": "Count",
              "operator": "LessThan",
              "threshold": "[parameters('ltmMinEvents')]",
              "failingPeriods": { "numberOfEvaluationPeriods": 2, "minFailingPeriodsToAlert": 2 }
            }
          ]
        },
        "autoMitigate": true,
        "skipQueryValidation": true,
        "actions": { "actionGroups": "[variables('actionGroups')]" }
      }
    },
    {
      "type": "Microsoft.Insights/scheduledQueryRules",
      "apiVersion": "2021-08-01",
      "name": "[concat(parameters('namePrefix'), '-ASM-Low-Ingestion')]",
      "location": "[parameters('location')]",
      "kind": "LogAlert",
      "properties": {
        "displayName": "[concat(parameters('namePrefix'), ' | ASM low ingestion')]",
        "description": "ASM/WAF event volume dropped below the expected floor over the last 60 minutes. ASM is event-driven and can be naturally sparse, so this rule uses a longer window and lower severity. Disable it or widen the window in environments with little WAF traffic.",
        "severity": 3,
        "enabled": true,
        "evaluationFrequency": "PT15M",
        "windowSize": "PT60M",
        "scopes": [ "[parameters('workspaceResourceId')]" ],
        "criteria": {
          "allOf": [
            {
              "query": "union isfuzzy=true (F5Telemetry_ASM_CL)\n| summarize Count = count()",
              "timeAggregation": "Total",
              "metricMeasureColumn": "Count",
              "operator": "LessThan",
              "threshold": "[parameters('asmMinEvents')]",
              "failingPeriods": { "numberOfEvaluationPeriods": 1, "minFailingPeriodsToAlert": 1 }
            }
          ]
        },
        "autoMitigate": true,
        "skipQueryValidation": true,
        "actions": { "actionGroups": "[variables('actionGroups')]" }
      }
    },
    {
      "type": "Microsoft.Insights/scheduledQueryRules",
      "apiVersion": "2021-08-01",
      "name": "[concat(parameters('namePrefix'), '-Ingestion-Latency-High')]",
      "location": "[parameters('location')]",
      "kind": "LogAlert",
      "properties": {
        "displayName": "[concat(parameters('namePrefix'), ' | Ingestion latency high (queue backlog)')]",
        "description": "p95 lag between F5 event time and the time Azure indexed the record exceeded the threshold over the last 15 minutes. Indicates the proxy persistent queue (shock absorber) is draining slowly because Azure is throttling, or the proxy is CPU/network constrained. Data is arriving but stale.",
        "severity": 2,
        "enabled": true,
        "evaluationFrequency": "PT5M",
        "windowSize": "PT15M",
        "scopes": [ "[parameters('workspaceResourceId')]" ],
        "criteria": {
          "allOf": [
            {
              "query": "union isfuzzy=true\n  (F5Telemetry_LTM_CL),\n  (F5Telemetry_ASM_CL),\n  (F5Telemetry_System_CL)\n| extend LagSeconds = (ingestion_time() - TimeGenerated) / 1s\n| summarize P95LagSeconds = percentile(LagSeconds, 95)",
              "timeAggregation": "Total",
              "metricMeasureColumn": "P95LagSeconds",
              "operator": "GreaterThan",
              "threshold": "[parameters('ingestionLagP95Seconds')]",
              "failingPeriods": { "numberOfEvaluationPeriods": 2, "minFailingPeriodsToAlert": 2 }
            }
          ]
        },
        "autoMitigate": true,
        "skipQueryValidation": true,
        "actions": { "actionGroups": "[variables('actionGroups')]" }
      }
    },
    {
      "type": "Microsoft.Insights/scheduledQueryRules",
      "apiVersion": "2021-08-01",
      "name": "[concat(parameters('namePrefix'), '-LTM-5xx-Error-Rate')]",
      "location": "[parameters('location')]",
      "kind": "LogAlert",
      "properties": {
        "displayName": "[concat(parameters('namePrefix'), ' | LTM 5xx error rate high')]",
        "description": "The share of LTM responses with a 5xx status exceeded the threshold over the last 15 minutes (with a built-in minimum-volume guard so low-traffic noise does not fire). Indicates backend/pool failure surfaced through the BIG-IP.",
        "severity": 1,
        "enabled": true,
        "evaluationFrequency": "PT5M",
        "windowSize": "PT15M",
        "scopes": [ "[parameters('workspaceResourceId')]" ],
        "criteria": {
          "allOf": [
            {
              "query": "F5Telemetry_LTM_CL\n| summarize Total = count(), Errors = countif(response_code_d >= 500)\n| where Total >= 50\n| extend ErrorRatePct = round(100.0 * Errors / Total, 2)",
              "timeAggregation": "Total",
              "metricMeasureColumn": "ErrorRatePct",
              "operator": "GreaterThan",
              "threshold": "[parameters('ltm5xxThresholdPct')]",
              "failingPeriods": { "numberOfEvaluationPeriods": 2, "minFailingPeriodsToAlert": 2 }
            }
          ]
        },
        "autoMitigate": true,
        "skipQueryValidation": true,
        "actions": { "actionGroups": "[variables('actionGroups')]" }
      }
    },
    {
      "type": "Microsoft.Insights/scheduledQueryRules",
      "apiVersion": "2021-08-01",
      "name": "[concat(parameters('namePrefix'), '-LTM-Latency-Degraded')]",
      "location": "[parameters('location')]",
      "kind": "LogAlert",
      "properties": {
        "displayName": "[concat(parameters('namePrefix'), ' | LTM p95 latency degraded')]",
        "description": "p95 LTM response time exceeded the threshold over the last 15 minutes (with a minimum-volume guard). Indicates backend slowness or BIG-IP saturation affecting end users.",
        "severity": 2,
        "enabled": true,
        "evaluationFrequency": "PT5M",
        "windowSize": "PT15M",
        "scopes": [ "[parameters('workspaceResourceId')]" ],
        "criteria": {
          "allOf": [
            {
              "query": "F5Telemetry_LTM_CL\n| summarize P95Ms = percentile(response_ms_d, 95), Requests = count()\n| where Requests >= 50",
              "timeAggregation": "Total",
              "metricMeasureColumn": "P95Ms",
              "operator": "GreaterThan",
              "threshold": "[parameters('ltmLatencyP95Ms')]",
              "failingPeriods": { "numberOfEvaluationPeriods": 2, "minFailingPeriodsToAlert": 2 }
            }
          ]
        },
        "autoMitigate": true,
        "skipQueryValidation": true,
        "actions": { "actionGroups": "[variables('actionGroups')]" }
      }
    },
    {
      "type": "Microsoft.Insights/scheduledQueryRules",
      "apiVersion": "2021-08-01",
      "name": "[concat(parameters('namePrefix'), '-ASM-Critical-Attack-Spike')]",
      "location": "[parameters('location')]",
      "kind": "LogAlert",
      "properties": {
        "displayName": "[concat(parameters('namePrefix'), ' | ASM critical attack spike')]",
        "description": "Blocked, Critical-severity ASM events for a single WAF policy exceeded the threshold in a 5-minute window. Alerts split per policy via the ASMPolicy dimension. Indicates an active attack campaign against a protected application.",
        "severity": 2,
        "enabled": true,
        "evaluationFrequency": "PT5M",
        "windowSize": "PT5M",
        "scopes": [ "[parameters('workspaceResourceId')]" ],
        "criteria": {
          "allOf": [
            {
              "query": "F5Telemetry_ASM_CL\n| where severity_s == 'Critical' and request_status_s == 'blocked'\n| summarize Count = count() by ASMPolicy = policy_name_s",
              "timeAggregation": "Total",
              "metricMeasureColumn": "Count",
              "operator": "GreaterThan",
              "threshold": "[parameters('asmCriticalThreshold')]",
              "dimensions": [
                { "name": "ASMPolicy", "operator": "Include", "values": [ "*" ] }
              ],
              "failingPeriods": { "numberOfEvaluationPeriods": 1, "minFailingPeriodsToAlert": 1 }
            }
          ]
        },
        "autoMitigate": true,
        "muteActionsDuration": "PT30M",
        "skipQueryValidation": true,
        "actions": { "actionGroups": "[variables('actionGroups')]" }
      }
    },
    {
      "type": "Microsoft.Insights/scheduledQueryRules",
      "apiVersion": "2021-08-01",
      "name": "[concat(parameters('namePrefix'), '-Device-Health-Degraded')]",
      "location": "[parameters('location')]",
      "kind": "LogAlert",
      "properties": {
        "displayName": "[concat(parameters('namePrefix'), ' | BIG-IP device health degraded')]",
        "description": "The most recent System Poller snapshot for a BIG-IP shows an unexpected failover state (not ACTIVE/STANDBY) or config-sync state (not In Sync/Standalone). Alerts split per device via the Host dimension. Catches failovers, FORCED_OFFLINE nodes, and pending/disconnected sync.",
        "severity": 1,
        "enabled": true,
        "evaluationFrequency": "PT5M",
        "windowSize": "PT15M",
        "scopes": [ "[parameters('workspaceResourceId')]" ],
        "criteria": {
          "allOf": [
            {
              "query": "F5Telemetry_System_CL\n| summarize arg_max(TimeGenerated, f5_device_failoverStatus_s, f5_device_syncStatus_s) by Host = f5_device_hostname_s\n| where f5_device_failoverStatus_s !in~ ('ACTIVE', 'STANDBY') or f5_device_syncStatus_s !in~ ('In Sync', 'Standalone')\n| summarize Count = count() by Host",
              "timeAggregation": "Total",
              "metricMeasureColumn": "Count",
              "operator": "GreaterThan",
              "threshold": 0,
              "dimensions": [
                { "name": "Host", "operator": "Include", "values": [ "*" ] }
              ],
              "failingPeriods": { "numberOfEvaluationPeriods": 1, "minFailingPeriodsToAlert": 1 }
            }
          ]
        },
        "autoMitigate": true,
        "skipQueryValidation": true,
        "actions": { "actionGroups": "[variables('actionGroups')]" }
      }
    },
    {
      "type": "Microsoft.Insights/scheduledQueryRules",
      "apiVersion": "2021-08-01",
      "name": "[concat(parameters('namePrefix'), '-Device-Saturation')]",
      "location": "[parameters('location')]",
      "kind": "LogAlert",
      "properties": {
        "displayName": "[concat(parameters('namePrefix'), ' | BIG-IP device CPU/memory saturated')]",
        "description": "The most recent System Poller snapshot for a BIG-IP shows system CPU or memory utilization above the configured threshold. Alerts split per device via the Host dimension. Relies on the f5_device_cpu_d / f5_device_memory_d columns promoted by the proxy's System Poller parsing (40-system.conf). Indicates the device is resource-constrained and at risk of dropping connections or shedding telemetry.",
        "severity": 2,
        "enabled": true,
        "evaluationFrequency": "PT5M",
        "windowSize": "PT15M",
        "scopes": [ "[parameters('workspaceResourceId')]" ],
        "criteria": {
          "allOf": [
            {
              "query": "[concat('F5Telemetry_System_CL\\n| summarize arg_max(TimeGenerated, f5_device_cpu_d, f5_device_memory_d) by Host = f5_device_hostname_s\\n| where f5_device_cpu_d > ', parameters('deviceCpuThresholdPct'), ' or f5_device_memory_d > ', parameters('deviceMemThresholdPct'), '\\n| summarize Count = count() by Host')]",
              "timeAggregation": "Total",
              "metricMeasureColumn": "Count",
              "operator": "GreaterThan",
              "threshold": 0,
              "dimensions": [
                { "name": "Host", "operator": "Include", "values": [ "*" ] }
              ],
              "failingPeriods": { "numberOfEvaluationPeriods": 1, "minFailingPeriodsToAlert": 1 }
            }
          ]
        },
        "autoMitigate": true,
        "skipQueryValidation": true,
        "actions": { "actionGroups": "[variables('actionGroups')]" }
      }
    }
  ],
  "outputs": {
    "alertRuleNames": {
      "type": "array",
      "value": [
        "[concat(parameters('namePrefix'), '-System-Heartbeat-Lost')]",
        "[concat(parameters('namePrefix'), '-Ingestion-Stopped')]",
        "[concat(parameters('namePrefix'), '-LTM-Low-Ingestion')]",
        "[concat(parameters('namePrefix'), '-ASM-Low-Ingestion')]",
        "[concat(parameters('namePrefix'), '-Ingestion-Latency-High')]",
        "[concat(parameters('namePrefix'), '-LTM-5xx-Error-Rate')]",
        "[concat(parameters('namePrefix'), '-LTM-Latency-Degraded')]",
        "[concat(parameters('namePrefix'), '-ASM-Critical-Attack-Spike')]",
        "[concat(parameters('namePrefix'), '-Device-Health-Degraded')]",
        "[concat(parameters('namePrefix'), '-Device-Saturation')]"
      ]
    }
  }
}
